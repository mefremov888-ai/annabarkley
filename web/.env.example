# Anna Barkley site — environment variables.
# Скопировать в `.env.local` и заполнить реальными значениями для прода/превью.
# Файлы .env*.local игнорируются git'ом.

# --- Базовый URL сайта (canonical, sitemap, OG) ---
NEXT_PUBLIC_SITE_URL=https://annabarkley.com

# --- Resend (форма /contact) ---
# Получить ключ: https://resend.com → API Keys → Create
# Если не задан — API /api/contact возвращает 501, форма падает на mailto.
RESEND_API_KEY=

# Куда приходят заявки. По умолчанию — AB_CONFIG.EMAIL.
CONTACT_TO_EMAIL=hello@annabarkley.com

# Адрес отправителя. Должен быть на верифицированном в Resend домене,
# иначе Resend разрешает только onboarding@resend.dev.
CONTACT_FROM_EMAIL=Anna Barkley <hello@annabarkley.com>

# --- Calendly (booking-кнопки) ---
# Реальная ссылка на ивент. Если не задана — кнопки ведут на /contact.
NEXT_PUBLIC_CALENDLY_URL=

# --- Аналитика (опционально) ---
# Загружается только после того как пользователь нажмёт "Accept all" в cookie-баннере.
NEXT_PUBLIC_GA4_ID=
# Цифровой ID счётчика (например 12345678), без префикса.
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# --- Sanity CMS (опционально, редактируемый блог) ---
# Создать проект: https://www.sanity.io/manage → Create new project
# После создания скопировать Project ID. Dataset обычно "production".
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# --- Координаты кабинета (опционально, для MapEmbed) ---
# Широта/долгота в десятичном формате, через запятую: 25.2048,55.2708
NEXT_PUBLIC_OFFICE_COORDS=
# Подпись на карте
NEXT_PUBLIC_OFFICE_NAME=Anna Barkley — Psychologist

# --- Сторонняя форм-интеграция (legacy fallback, опционально) ---
NEXT_PUBLIC_FORMS_ENDPOINT=
